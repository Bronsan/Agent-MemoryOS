# Memory Core Configuration
# Copy to .env and adjust before deploying. NEVER commit .env to version control.

# =============================================================================
# Server
# =============================================================================
HTTP_PORT=8080
GRPC_PORT=9090
# TLS_ENABLED=false
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem

# =============================================================================
# PostgreSQL (pgvector required)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=memoryos
DB_PASSWORD=changeme
DB_NAME=memoryos
DB_SSLMODE=require

# =============================================================================
# Redis (optional — hot cache layer)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# SQLite (session cache)
# =============================================================================
SQLITE_PATH=./data/sessions.db

# =============================================================================
# Object Storage (S3-compatible, optional)
# =============================================================================
# OBJ_ENDPOINT=localhost:9000
# OBJ_ACCESS_KEY=minioadmin
# OBJ_SECRET_KEY=minioadmin
# OBJ_BUCKET=memoryos-raw
# OBJ_USE_SSL=false

# =============================================================================
# Embedding Model
# =============================================================================
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# EMBEDDING_API_KEY=sk-...      # Required for OpenAI
# EMBEDDING_BASE_URL=            # Override API base URL (Ollama: http://localhost:11434)

# =============================================================================
# LLM (summarization, entity extraction, reranking)
# =============================================================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...             # Required for OpenAI
# LLM_BASE_URL=                  # Override API base URL

# =============================================================================
# Async Worker Pool
# =============================================================================
WORKER_CONCURRENCY=4
WORKER_QUEUE_SIZE=1000

# =============================================================================
# Security (CRITICAL — change these in production)
# =============================================================================
# Generate: openssl rand -base64 64
AUTH_JWT_SECRET=your-secret-key-change-in-production
AUTH_ENABLE_API_KEY=true

# Rate limiting
SEC_RATE_LIMIT_RPS=100
SEC_RATE_LIMIT_BURST=200

# =============================================================================
# Plugins
# =============================================================================
PLUGINS_ENABLED=discord,telegram,github
